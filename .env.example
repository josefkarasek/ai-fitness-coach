# Backend HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=info

# Local PostgreSQL used by Tilt
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_fitness_coach?sslmode=disable

# Authentication
# Use "disabled" for anonymous local backend work.
# Use "firebase" when testing the Flutter -> backend authenticated flow.
AUTH_MODE=disabled
FIREBASE_PROJECT_ID=ai-fitness-coach-c0d30

# Backend-only Firebase Admin SDK credential.
# This is the private service-account JSON downloaded from Firebase Console
# -> Project settings -> Service accounts -> Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-admin.json

# AI
# The backend owns all AI calls. The mobile client should only trigger
# bounded actions such as "explain workout" or "generate plan".
# Local development can use the built-in mock provider.
AI_PROVIDER=mock
AI_MODEL=mock-workout-explainer-v1
AI_BASE_URL=
AI_API_KEY=

# Simple server-side guardrail against runaway per-user usage.
# For local development, a slightly higher training-plan limit is useful
# because regenerating mock blocks is part of the iteration loop.
AI_DAILY_WORKOUT_EXPLANATIONS_LIMIT=3
AI_DAILY_WORKOUT_REVIEWS_LIMIT=12
AI_DAILY_TRAINING_PLANS_LIMIT=3
